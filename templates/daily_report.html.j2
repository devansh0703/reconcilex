<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reconciliation Report - {{ date }}</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Arial, sans-serif; background: #f0f2f5; color: #333; }
        .container { max-width: 1200px; margin: 0 auto; padding: 20px; }
        .header { background: linear-gradient(135deg, #1a237e 0%, #283593 100%); color: white; padding: 30px; border-radius: 12px; margin-bottom: 20px; }
        .header h1 { font-size: 28px; margin-bottom: 8px; }
        .header .date { opacity: 0.8; font-size: 16px; }
        .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px; margin: 20px 0; }
        .card { background: white; padding: 20px; border-radius: 10px; box-shadow: 0 2px 8px rgba(0,0,0,0.08); border-left: 4px solid #1a237e; }
        .card.matched { border-left-color: #4caf50; }
        .card.warning { border-left-color: #ff9800; }
        .card.error { border-left-color: #f44336; }
        .card h3 { font-size: 13px; color: #666; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 8px; }
        .card .value { font-size: 32px; font-weight: 700; color: #1a237e; }
        .section { background: white; border-radius: 10px; padding: 24px; margin: 20px 0; box-shadow: 0 2px 8px rgba(0,0,0,0.08); }
        .section h2 { color: #1a237e; margin-bottom: 16px; font-size: 20px; border-bottom: 2px solid #e8eaf6; padding-bottom: 8px; }
        table { width: 100%; border-collapse: collapse; }
        th { background: #1a237e; color: white; padding: 12px 16px; text-align: left; font-size: 13px; text-transform: uppercase; letter-spacing: 0.5px; }
        td { padding: 10px 16px; border-bottom: 1px solid #eee; font-size: 14px; }
        tr:hover { background: #f8f9fa; }
        .status { padding: 4px 12px; border-radius: 20px; font-size: 12px; font-weight: 600; }
        .status-matched { background: #e8f5e9; color: #2e7d32; }
        .status-qty { background: #fff3e0; color: #f57c00; }
        .status-price { background: #fff3e0; color: #f57c00; }
        .status-missing { background: #ffebee; color: #c62828; }
        .footer { text-align: center; padding: 20px; color: #999; font-size: 12px; }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>Post-Trade Reconciliation Report</h1>
            <div class="date">{{ date }}</div>
        </div>

        <div class="grid">
            <div class="card matched">
                <h3>Internal Trades</h3>
                <div class="value">{{ total_internal }}</div>
            </div>
            <div class="card matched">
                <h3>Broker Confirmations</h3>
                <div class="value">{{ total_confirmations }}</div>
            </div>
            <div class="card matched">
                <h3>Matched</h3>
                <div class="value">{{ matched }}</div>
            </div>
            <div class="card warning">
                <h3>Match Rate</h3>
                <div class="value">{{ "%.1f"|format(match_rate) }}%</div>
            </div>
        </div>

        <div class="grid">
            <div class="card warning">
                <h3>Qty Mismatches</h3>
                <div class="value">{{ qty_mismatch }}</div>
            </div>
            <div class="card warning">
                <h3>Price Mismatches</h3>
                <div class="value">{{ price_mismatch }}</div>
            </div>
            <div class="card error">
                <h3>Missing Broker</h3>
                <div class="value">{{ missing_broker }}</div>
            </div>
            <div class="card error">
                <h3>Missing Internal</h3>
                <div class="value">{{ missing_internal }}</div>
            </div>
        </div>

        {% if exceptions %}
        <div class="section">
            <h2>Exceptions ({{ exceptions|length }})</h2>
            <table>
                <thead>
                    <tr>
                        <th>Trade ID</th>
                        <th>Symbol</th>
                        <th>Type</th>
                        <th>Details</th>
                    </tr>
                </thead>
                <tbody>
                    {% for ex in exceptions %}
                    <tr>
                        <td>{{ ex.trade_id }}</td>
                        <td>{{ ex.symbol | default('N/A') }}</td>
                        <td><span class="status status-{{ ex.type | default('missing') }}">{{ ex.type }}</span></td>
                        <td>{{ ex.description | default(ex.details | default('')) }}</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
        {% endif %}

        <div class="footer">
            ReconcileX - Tower Research Capital - Generated {{ date }}
        </div>
    </div>
</body>
</html>
